NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
NEXT_PUBLIC_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=0.1

# Canonical URL for sitemaps, OG tags, and robots (falls back to VERCEL_URL in production)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Optional: footer social links (defaults to generic homepages if unset)
NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/
NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://www.facebook.com/
NEXT_PUBLIC_SOCIAL_YOUTUBE_URL=https://www.youtube.com/

# Ads provider: none | adsense | gam
NEXT_PUBLIC_AD_PROVIDER=none

# AdSense config
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx
NEXT_PUBLIC_ADSENSE_SLOT_INLINE=0000000000
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_1=0000000001
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_2=0000000002

# Google Ad Manager config (full ad unit paths)
NEXT_PUBLIC_GAM_SLOT_INLINE=/1234567/home_inline
NEXT_PUBLIC_GAM_SLOT_SIDEBAR_1=/1234567/sidebar_top
NEXT_PUBLIC_GAM_SLOT_SIDEBAR_2=/1234567/sidebar_bottom

# AI provider: fallback | openai | anthropic
AI_PROVIDER=fallback
AI_PROVIDER_TIMEOUT_MS=12000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Newsletter provider: none | resend | mailchimp
NEWSLETTER_PROVIDER=none
NEWSLETTER_PROVIDER_TIMEOUT_MS=10000
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
